# BlackBeetle Deploy Configuration
# Copy this file to .deploy.env and fill in the values

# ── FTP settings (used with --ftp flag, also as SFTP fallback) ────
# Server hostname (e.g., your-server.com)
DEPLOY_FTP_HOST=

# FTP username (e.g., deploy-frontend)
DEPLOY_FTP_USER=

# FTP password (use single quotes if it contains special chars: $ ! # etc.)
DEPLOY_FTP_PASS=''

# ── SFTP settings (default deploy method, faster than FTP) ────────
# Leave blank to reuse the FTP values above
DEPLOY_SSH_HOST=
DEPLOY_SSH_USER=
DEPLOY_SSH_PASS=''
DEPLOY_SSH_PORT=22

# ── Remote path ───────────────────────────────────────────────────
# Remote path on the server
# The deploy-frontend user is chroot'd to /blacknectar.de/httpdocs,
# so the deploy path is just /
DEPLOY_PATH=/
