# BlackBeetle Frontend Environment Variables
# Copy this file to .env and fill in the values

# Laravel API Base URL (e.g., https://api.yourdomain.com)
NUXT_PUBLIC_API_BASE=

# Backend URL for static assets/images (e.g., https://api.yourdomain.com)
NUXT_PUBLIC_BACKEND_URL=

# LightGallery License Key (optional, for production use)
NUXT_PUBLIC_LG_LICENSE_KEY=
